# Copy to `.env` and fill in. The CLI auto-loads .env on every invocation.
# .env is gitignored — never commit your real keys.

# Required for `tt parse` and `tt ask` (Claude API for natural-language parsing).
ANTHROPIC_API_KEY=sk-ant-...

# Required for production: Discord bot token from the Discord Developer Portal.
DISCORD_BOT_TOKEN=

# Optional: restrict the bot to one channel ID. If unset, responds in any channel it can see.
# DISCORD_CHANNEL_ID=123456789012345678
